{
  "name": "my-angular-lib",
  "version": "0.0.0",
  "workspaces": [
    "projects/my-lib"
  ],
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "dev": "concurrently \"ng build my-lib --watch\" \"ng serve angular-learning-lab\"",
    "build:storybook": "ng run my-lib:build-storybook",
    "run:storybook": "ng run my-lib:storybook",
    "serve:storybook": "npm run build:storybook && npm run run:storybook",
    "build:lib": "ng build my-lib --configuration production",
    "test:lib": "ng test my-lib",
    "build:app": "ng build angular-learning-lab --configuration production",
    "build:app:pages": "ng build angular-learning-lab --configuration production --base-href /my-angular-lib/",
    "build:all": "npm run build:lib && npm run build:app",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "npm run build:lib && changeset publish"
  },
  "prettier": {
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^21.2.8",
    "@angular/compiler": "^21.2.8",
    "@angular/core": "^21.2.8",
    "@angular/forms": "^21.2.8",
    "@angular/platform-browser": "^21.2.8",
    "@angular/router": "^21.2.8",
    "@eagle009/spaa-angular-lib": "^0.0.3",
    "@ngrx/effects": "^21.1.0",
    "@ngrx/entity": "^21.1.0",
    "@ngrx/router-store": "^21.1.0",
    "@ngrx/signals": "^21.1.0",
    "@ngrx/store": "^21.1.0",
    "@ngrx/store-devtools": "^21.1.0",
    "@types/ramda": "^0.32.0",
    "ramda": "^0.32.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-devkit/architect": "^0.2102.7",
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.8",
    "@angular/platform-browser-dynamic": "^21.2.8",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@compodoc/compodoc": "^1.2.1",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-onboarding": "^10.3.5",
    "@storybook/angular": "^10.3.5",
    "@types/jasmine": "~5.1.0",
    "jasmine-core": "~5.8.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "ng-packagr": "^21.2.2",
    "storybook": "^10.3.5",
    "typescript": "~5.9.3"
  }
}

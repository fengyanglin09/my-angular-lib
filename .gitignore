# Root Git ignore rules for this monorepo

# Dependencies
**/node_modules/

# Build and test outputs
**/dist/
**/tmp/
**/out-tsc/
**/coverage/
**/.angular/
/bazel-out
/storybook-static

# Nx cache/work data
**/.nx/cache/
**/.nx/workspace-data/
**/.nx/polygraph/

# Vite/Vitest temporary timestamp artifacts
**/vite.config.*.timestamp*
**/vitest.config.*.timestamp*

# Editor and local AI tooling state
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
**/.cursor/
**/.codex/
**/.claude/
**/.gemini/
**/.opencode/
**/.agents/
.history/

# Playwright local cache folder
**/.playwright-mcp/

# Logs and OS junk
**/npm-debug.log*
**/yarn-error.log*
*storybook.log
**/testem.log
.DS_Store
Thumbs.db
/connect.lock
/libpeerconnection.log
/typings
/.husky/
/.vscode/
